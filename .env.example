# --- AI provider (server-side only) ---
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4.1-mini"

# --- Job search provider ---
ADZUNA_APP_ID="YOUR_ADZUNA_APP_ID"
ADZUNA_APP_KEY="YOUR_ADZUNA_APP_KEY"
ADZUNA_COUNTRY="us"

# --- Frontend -> backend API base URL ---
# In local development you can leave empty to use same-origin requests.
# In production/mobile builds set this to your deployed API, e.g. https://api.example.com
VITE_API_BASE_URL=""

# --- Server ---
PORT="3000"
NODE_ENV="development"
