# --- Firebase Web SDK (frontend) ---
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_WEB_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="1234567890"
VITE_FIREBASE_APP_ID="1:1234567890:web:abcdef123456"
# Optional if you use a named Firestore DB instead of (default)
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
# Optional feature flags
VITE_ENABLE_APPLE_AUTH="false"

# --- Firebase token verification (backend, optional but recommended) ---
# Used by backend middleware to verify Firebase ID tokens.
FIREBASE_WEB_API_KEY="YOUR_FIREBASE_WEB_API_KEY"

# --- AI provider (server-side only) ---
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4.1-mini"

# --- Job search provider ---
ADZUNA_APP_ID="YOUR_ADZUNA_APP_ID"
ADZUNA_APP_KEY="YOUR_ADZUNA_APP_KEY"
ADZUNA_COUNTRY="us"

# --- Frontend -> backend API base URL ---
# In local development you can leave empty to use same-origin requests.
# In production/mobile builds set this to your deployed API, e.g. https://api.example.com
VITE_API_BASE_URL=""

# --- Server ---
PORT="3000"
NODE_ENV="development"
