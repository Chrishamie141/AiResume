{
  "entities": {
    "User": {
      "title": "User",
      "description": "Basic user information and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Detailed professional background and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "links": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "portfolio": { "type": "string" },
            "github": { "type": "string" }
          }
        },
        "summary": { "type": "string" },
        "education": { "type": "array", "items": { "type": "object" } },
        "experience": { "type": "array", "items": { "type": "object" } },
        "projects": { "type": "array", "items": { "type": "object" } },
        "coursework": { "type": "array", "items": { "type": "object" } },
        "certifications": { "type": "array", "items": { "type": "object" } },
        "skills": {
          "type": "object",
          "properties": {
            "technical": { "type": "array", "items": { "type": "string" } },
            "soft": { "type": "array", "items": { "type": "string" } }
          }
        },
        "preferences": {
          "type": "object",
          "properties": {
            "industries": { "type": "array", "items": { "type": "string" } },
            "titles": { "type": "array", "items": { "type": "string" } },
            "locations": { "type": "array", "items": { "type": "string" } },
            "workType": { "type": "string" },
            "salary": { "type": "string" },
            "visa": { "type": "string" },
            "yearsOfExperience": { "type": "number" }
          }
        }
      },
      "required": ["uid"]
    },
    "Resume": {
      "title": "Resume",
      "description": "A generated resume document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "templateId": { "type": "string" },
        "style": { "type": "string" },
        "isBase": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "content"]
    },
    "JobApplication": {
      "title": "JobApplication",
      "description": "Tracking a specific job application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "jobId": { "type": "string" },
        "resumeId": { "type": "string" },
        "coverLetterId": { "type": "string" },
        "status": { "type": "string", "enum": ["saved", "ready", "applied", "interview", "rejected", "offer"] },
        "notes": { "type": "string" },
        "appliedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "jobId", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User account data" },
    "/userProfiles/{uid}": { "schema": "UserProfile", "description": "Professional profile" },
    "/resumes/{resumeId}": { "schema": "Resume", "description": "Stored resumes" },
    "/jobApplications/{applicationId}": { "schema": "JobApplication", "description": "Application tracking records" }
  }
}
