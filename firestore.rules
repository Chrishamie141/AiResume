rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    // User profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    match /userProfiles/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // Resumes
    match /resumes/{resumeId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isNewDocOwner();
      allow update, delete: if isDocOwner();
    }

    // Job Applications
    match /jobApplications/{applicationId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isNewDocOwner();
      allow update, delete: if isDocOwner();
    }
  }
}
